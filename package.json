{
  "name": "demo-homework",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "docs:project-selection-analysis": "bun run docs/project-selection-analysis.html",
    "docs:project-requirements": "PORT=3001 bun run docs/project-requirements.html",
    "docs:project-tech-design": "PORT=3002 bun run docs/project-tech-design.html",
    "docs:project-dev-plan": "PORT=3003 bun run docs/project-dev-plan.html",
    "check-env": "pwsh -File scripts/check-env.ps1",
    "dev:up": "docker-compose -f infra/docker-compose.dev.yml --env-file infra/.env up -d",
    "dev:down": "docker-compose -f infra/docker-compose.dev.yml --env-file infra/.env down",
    "dev:reset": "docker-compose -f infra/docker-compose.dev.yml --env-file infra/.env down -v",
    "dev:logs": "docker-compose -f infra/docker-compose.dev.yml --env-file infra/.env logs -f",
    "dev:ps": "docker-compose -f infra/docker-compose.dev.yml ps",
    "be:dev": "cd ats-backend && ./mvnw spring-boot:run",
    "fe:dev": "cd ats-frontend && bun run dev",
    "fe:build": "cd ats-frontend && bun run build"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@lumirelle/oxlint-config": "^0.6.0",
    "@lumirelle/tsconfig": "^0.1.4",
    "bun-types": "^1.3.14",
    "cursor": "^0.1.5",
    "eslint": "^10.4.0",
    "eslint-plugin-oxlint": "^1.66.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  }
}
