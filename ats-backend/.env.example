# ─────────────────────────────────────────────────────────────
#  ats-backend 环境变量
#  复制为 .env 后填入实际值；Spring Boot 通过 spring.config.import 读取
# ─────────────────────────────────────────────────────────────

SERVER_PORT=8080

# ── Database ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ats_db
DB_USER=ats_user
DB_PASSWORD=ats_pwd

# ── Redis ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT (RS256) ─────────────────────────────────────
# 通过 scripts/new-jwt-keys.ps1 生成，base64 后粘贴
# 单引号包裹避免 $ 被 shell 转义
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ACCESS_TTL_SECONDS=7200
JWT_REFRESH_TTL_SECONDS=604800
JWT_ISSUER=ats.local

# ── File upload ─────────────────────────────────────
UPLOAD_PATH=./uploads
UPLOAD_MAX_FILE_MB=5
